# =============================================================================
# TechUties AI Platform - Environment Configuration Template
# =============================================================================
# Version: 3.0.0
# Description: Production-ready AI platform with MinIO, Tika, and enhanced security
# =============================================================================
# 
# IMPORTANT: Copy this file to .env and generate secure passwords!
# Run: ./tu-vm.sh generate-secrets
# =============================================================================

# =============================================================================
# HOST & DOMAIN CONFIGURATION
# =============================================================================
# HOST_IP will be auto-detected on first start, or set manually:
# HOST_IP=192.168.1.100
HOST_IP=
# Optional: Tailscale IPv4 of this VM (auto-detected when available)
TAILSCALE_IP=
# Optional override for Pi-hole local DNS records (*.tu.lan)
# If empty, tu-vm.sh uses: DNS_RECORD_IP -> HOST_IP -> TAILSCALE_IP
DNS_RECORD_IP=
DOMAIN=tu.lan

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
POSTGRES_DB=ai_platform
POSTGRES_USER=ai_admin
POSTGRES_PASSWORD=CHANGE_ME_SECURE_PASSWORD

# =============================================================================
# REDIS CONFIGURATION
# =============================================================================
REDIS_PASSWORD=CHANGE_ME_SECURE_PASSWORD

# =============================================================================
# N8N WORKFLOW AUTOMATION
# =============================================================================
N8N_USER=admin
N8N_PASSWORD=CHANGE_ME_SECURE_PASSWORD
N8N_ENCRYPTION_KEY=CHANGE_ME_32_CHAR_ENCRYPTION_KEY
N8N_API_KEY=
N8N_REQUIRE_API_KEY=true
N8N_INTERNAL_URL=http://ai_n8n:5678
N8N_ALLOWED_WORKFLOW_IDS=
N8N_MCP_ENABLED=true
N8N_TLS_VERIFY=false

# =============================================================================
# OPEN WEBUI CONFIGURATION
# =============================================================================
WEBUI_SECRET_KEY=CHANGE_ME_SECRET_KEY
WEBUI_JWT_SECRET_KEY=CHANGE_ME_JWT_SECRET_KEY
WEBUI_AUTH_SECRET=CHANGE_ME_AUTH_SECRET
# Web search: fetch result pages without a browser (Playwright Chromium is not bundled in the stock image).
WEB_LOADER_ENGINE=safe_web
# Optional JS-capable web search: run Tier 2 service `browserless`, then point Open WebUI at it.
# Same secret must be used in TOKEN (browserless) and in the query string below.
# BROWSERLESS_TOKEN=CHANGE_ME_LONG_RANDOM
# PLAYWRIGHT_WS_URL=ws://browserless:3000/chromium/playwright?token=CHANGE_ME_LONG_RANDOM
# WEB_LOADER_ENGINE=playwright
# PLAYWRIGHT_TIMEOUT=60000

# =============================================================================
# MINIO OBJECT STORAGE
# =============================================================================
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=CHANGE_ME_SECURE_PASSWORD

# =============================================================================
# AFFINE COLLABORATIVE WORKSPACE
# =============================================================================
# Required for AFFiNE self-hosted stack in docker-compose.yml
AFFINE_DB_USER=affine
AFFINE_DB_PASSWORD=affine_change_me
AFFINE_DB_NAME=affine

# AFFiNE MCP integration (Open WebUI tool access through mcp_gateway)
AFFINE_MCP_ENABLED=true
# Create token in AFFiNE UI: Settings -> Tokens
AFFINE_API_TOKEN=
# Optional alternative auth methods (only if not using API token)
AFFINE_COOKIE=
AFFINE_EMAIL=
AFFINE_PASSWORD=
# Internal URL used by mcp_gateway to reach AFFiNE
AFFINE_BASE_URL=http://ai_affine:3010

# MCP Gateway security and server selection
MCP_GATEWAY_TOKEN=CHANGE_ME_MCP_TOKEN
MCP_ALLOWED_SERVERS=affine,n8n,kb
MCP_AFFINE_COMMAND=affine-mcp
MCP_AFFINE_ARGS=
MCP_EXECUTION_KILL_SWITCH=false
MCP_PROOF_SIGNING_KEY=CHANGE_ME_PROOF_HMAC
MCP_PROOF_STORE_PATH=/var/lib/mcp-gateway/proof-store.json
MCP_DEDUPE_STORE_PATH=/var/lib/mcp-gateway/dedupe-store.json
MCP_DLQ_STORE_PATH=/var/lib/mcp-gateway/dlq-store.json
MCP_WRITE_APPROVAL_REQUIRED=false
MCP_WRITE_APPROVAL_TOKENS=
MCP_DEFAULT_TENANT_ID=oweb-default
MCP_DEFAULT_ACTOR_ID=oweb-operator
MCP_DEFAULT_CONVERSATION_PREFIX=oweb
KB_MCP_ENABLED=true
KB_PUBLIC_READ_ENABLED=true
KB_MINIO_ENDPOINT=minio:9000
KB_MINIO_ACCESS_KEY=admin
KB_MINIO_SECRET_KEY=CHANGE_ME_SECURE_PASSWORD
KB_MINIO_SECURE=false
KB_PUBLIC_BUCKET=kb-public
KB_PRIVATE_BUCKET=kb-private
KB_INDEX_PREFIX=.index/
KB_TIKA_URL=http://tika:9998
KB_TIKA_TIMEOUT_SECONDS=45
KB_MAX_OBJECT_BYTES=10485760
KB_MAX_EXTRACT_CHARS=120000

# Tenant controls for multi-tenant execution
TENANT_REQUESTS_PER_MINUTE=120
TENANT_MAX_CONCURRENCY=4
TENANT_DAILY_WRITES=4000

# LangGraph supervisor
MCP_GATEWAY_URL=http://ai_mcp_gateway:9002
LANGGRAPH_SUPERVISOR_ENABLED=true
LANGGRAPH_SUPERVISOR_REQUIRED=true
LANGGRAPH_SUPERVISOR_URL=http://ai_langgraph_supervisor:9010
# Optional dedicated token for supervisor endpoint auth. Leave empty to reuse MCP_GATEWAY_TOKEN.
LANGGRAPH_SUPERVISOR_TOKEN=
LANGGRAPH_STRICT_VERIFY=true
LANGGRAPH_AUDIT_PATH=/var/lib/langgraph-supervisor/audit.json
LANGGRAPH_CHECKPOINT_PATH=/var/lib/langgraph-supervisor/checkpoints.json
LANGGRAPH_DEDUPE_PATH=/var/lib/langgraph-supervisor/dedupe.json

# =============================================================================
# PI-HOLE DNS CONFIGURATION
# =============================================================================
PIHOLE_PASSWORD=CHANGE_ME_SECURE_PASSWORD

# =============================================================================
# SSL/TLS CONFIGURATION
# =============================================================================
CERTBOT_EMAIL=info@techuties.com
COUNTRY=CH
CITY=Zurich

# =============================================================================
# RESOURCE LIMITS & OPTIMIZATION
# =============================================================================
OLLAMA_GPU_MEMORY=8G
POSTGRES_MEMORY=2G
REDIS_MEMORY=1G
MINIO_MEMORY=1G

# =============================================================================
# MONITORING & OBSERVABILITY
# =============================================================================
ENABLE_METRICS=true
LOG_LEVEL=INFO
ENABLE_TRACING=false

# =============================================================================
# BACKUP CONFIGURATION
# =============================================================================
BACKUP_RETENTION_DAYS=30
BACKUP_COMPRESSION=true
BACKUP_ENCRYPTION=true

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================
ENABLE_RATE_LIMITING=true
ENABLE_CORS=true
ENABLE_CSRF_PROTECTION=true
SESSION_TIMEOUT=3600

# Dashboard Control Token (for service management and allowlist control)
# Generated automatically by: ./tu-vm.sh generate-secrets
CONTROL_TOKEN=CHANGE_ME_CONTROL_TOKEN

# =============================================================================
# ADVANCED CONFIGURATION
# =============================================================================
# Connection pooling
POSTGRES_MAX_CONNECTIONS=100
POSTGRES_SHARED_BUFFERS=256MB
POSTGRES_EFFECTIVE_CACHE_SIZE=1GB

# Redis optimization
REDIS_MAXMEMORY=256mb
REDIS_MAXMEMORY_POLICY=allkeys-lru

# Nginx optimization
NGINX_WORKER_PROCESSES=auto
NGINX_WORKER_CONNECTIONS=1024
NGINX_KEEPALIVE_TIMEOUT=65

# Health check intervals (seconds)
HEALTH_CHECK_INTERVAL=30
HEALTH_CHECK_TIMEOUT=10
HEALTH_CHECK_RETRIES=3

# =============================================================================
# SERVICE-SPECIFIC CONFIGURATION
# =============================================================================
# Apache Tika Configuration
TIKA_SERVER_PORT=9998
TIKA_LOG_LEVEL=INFO

# MinIO Configuration
MINIO_CONSOLE_ADDRESS=:9001
MINIO_SERVER_URL=https://api.minio.tu.lan
MINIO_BROWSER_REDIRECT_URL=https://minio.tu.lan

# =============================================================================
# SECURITY WARNINGS
# =============================================================================
# WARNING: Never use default passwords in production!
# WARNING: Generate strong, unique passwords for each service!
# WARNING: Store passwords securely and rotate them regularly!
# WARNING: This template contains placeholder values that MUST be changed!